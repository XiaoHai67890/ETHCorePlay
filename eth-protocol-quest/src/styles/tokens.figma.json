    "text.primary": {
      "$type": "color",
      "$value": "#F3F5FF"
    },
    "text.secondary": {
      "$type": "color",
      "$value": "#C6CBE0"
    },
    "border.default": {
      "$type": "color",
      "$value": "rgba(255,255,255,0.14)"
    },
    "brand.primary": {
      "$type": "color",
      "$value": "#627EEA"
    },
    "brand.garden": {
      "$type": "color",
      "$value": "#3BCB93"
    }

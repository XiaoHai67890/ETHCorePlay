{
  "$themes": [
    {
      "id": "light",
      "name": "Light"
    },
    {
      "id": "dark",
      "name": "Dark"
    }
  ],
  "$metadata": {
    "tokenSetOrder": [
      "global",
      "theme/light",
      "theme/dark"
    ]
  },
  "global": {
    "radius.1": {
      "$type": "borderRadius",
      "$value": "6"
    },
    "radius.2": {
      "$type": "borderRadius",
      "$value": "10"
    },
    "radius.3": {
      "$type": "borderRadius",
      "$value": "14"
    },
    "radius.4": {
      "$type": "borderRadius",
      "$value": "18"
    }
  },
  "theme/light": {
    "bg.canvas": {
      "$type": "color",
      "$value": "#F7F8FB"
    },
    "bg.surface": {
      "$type": "color",
      "$value": "#FFFFFF"
    },
    "text.primary": {
      "$type": "color",
      "$value": "#0B0D12"
    },
    "text.secondary": {
      "$type": "color",
      "$value": "#424A5C"
    },
    "border.default": {
      "$type": "color",
      "$value": "#CBD3E3"

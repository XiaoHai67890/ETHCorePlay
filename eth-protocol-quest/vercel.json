{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/((?!assets/|cms/|favicon.svg|og.svg).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/cms/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
